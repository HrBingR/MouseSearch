FLASK_SECRET_KEY=a-very-secret-key

# enter your MAM ID and UID from https://mousesearch.org/settings
MAM_ID=mam_id_here-generated-from-myanonamouse-website
MAM_UID=your_mam_user_id_here

# QBittorrent Settings & Credentials
QB_URL=http://qbittorrent:6767
QB_USERNAME=your_qbittorrent_username
QB_PASSWORD=your_qbittorrent_password
QB_CATEGORY=audiobooks # default qBittorrent category to use for downloads

# Config and State File Paths
METADATA_FILE=./data/metadata.json
IP_STATE_FILE=./data/ip_state.json
CONFIG_FILE=./data/config.json

# Download Storage Paths
# - if using AUTO_ORGANIZE, ensure these paths are on the same device
# - (and Docker volume, if running in Docker) to ensure hard links can be created
ORGANIZED_PATH=/downloads/organized/audiobooks
QB_PATH=/downloads/torrents/organize-these/audiobooks


# Recommended File Structure 

# downloads
# ├── organized
# │   ├── audiobooks
# │   └── ebooks
# └── torrents
#     ├── dont-organize-these
#     └── organize-these
#         ├── audiobooks
#         └── ebooks

# Enable this to have MouseSearch automatically hard link files
# from the "organize-these" folder to the "organized" folder in Author/Title format.
AUTO_ORGANIZE=true

# CF_ACCESS_CLIENT_ID=
# CF_ACCESS_CLIENT_SECRET=

